PRIVATE_KEY=0x...
POLY_PROXY_ADDRESS=0x... (Optional: Gnosis Safe Address)

# Primary RPC
RPC_URL=https://polygon-rpc.com

# Backup RPCs (Optional)
RPC_URL_1=
RPC_URL_2=

# Relayer V2 API Keys (Gasless Transactions)
# Format 1: RELAYER_API_KEY / RELAYER_API_KEY_ADDRESS
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=

# Format 2: Numbered alternates for multiple accounts (Fallback rotation)
1RELAYER_API_KEY=
1RELAYER_API_KEY_ADDRESS=

2RELAYER_API_KEY=
2RELAYER_API_KEY_ADDRESS=

3RELAYER_API_KEY=
3RELAYER_API_KEY_ADDRESS=

4RELAYER_API_KEY=
4RELAYER_API_KEY_ADDRESS=
